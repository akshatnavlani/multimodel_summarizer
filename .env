# =============================================================================
# .env — Multimodal Summarizer + XAI  (DO NOT COMMIT THIS FILE)
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyCFXHJ_QQMcc8ic-YMRF4pv-ATecuJZ9KI
GOOGLE_API_KEY=AIzaSyCFXHJ_QQMcc8ic-YMRF4pv-ATecuJZ9KI
GEMINI_MODEL=gemini-2.0-flash

PROJECT_ROOT=/home/sonic/Downloads/root

# ── Optional ──────────────────────────────────────────────────────────────────
# GROQ_API_KEY=

TRANSFORMERS_CACHE=/home/sonic/Downloads/root/.model_cache
HF_HOME=/home/sonic/Downloads/root/.model_cache

# Set to 1 to enable local BART (slow — skip for now)
ENABLE_BART=0

# Optional local LLM fallback via Ollama
# OLLAMA_MODEL=gemma3:4b-instruct-q4_K_M
# OLLAMA_BASE_URL=http://localhost:11434

# RTX 3050 / low-VRAM tuning
BLIP2_BATCH_SIZE=1
DEPLOT_BATCH_SIZE=1
GPU_MIN_FREE_GB_FOR_VISION=0.8
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True,garbage_collection_threshold:0.8,max_split_size_mb:128

# Gemini request pacing
GEMINI_RATE_LIMIT_COOLDOWN_SECONDS=900
GEMINI_MIN_REQUEST_INTERVAL_SECONDS=2

# Runtime debug telemetry (written to logs/api_debug.jsonl and logs/vision_debug.jsonl)
API_DEBUG_LOG=1
VISION_DEBUG_LOG=1

# BLIP fallback for low-VRAM GPUs if BLIP-2 cannot load
BLIP_FALLBACK_MODEL_ID=Salesforce/blip-image-captioning-large

# Retry transient Gemini 429 responses before cooldown
GEMINI_RETRY_ON_429=2
GEMINI_RETRY_BASE_SECONDS=2
